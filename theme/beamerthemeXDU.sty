\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeXDU}[2026/05/14 XDU beamer theme]

\RequirePackage{etoolbox}
\RequirePackage{tikz}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{pifont}

\usetikzlibrary{calc,positioning}

\mode<presentation>

\definecolor{xdured}{RGB}{192,0,0}
\definecolor{xdured2}{RGB}{220,60,60}
\definecolor{xdulight}{RGB}{252,242,242}
\definecolor{xdugray}{RGB}{90,90,90}
\definecolor{xdudark}{RGB}{40,40,40}

\setbeamercolor{normal text}{fg=xdudark,bg=white}
\setbeamercolor{structure}{fg=xdured}
\setbeamercolor{frametitle}{fg=xdured,bg=white}
\setbeamercolor{title}{fg=xdured}
\setbeamercolor{subtitle}{fg=xdugray}
\setbeamercolor{block title}{fg=white,bg=xdured}
\setbeamercolor{block body}{fg=xdudark,bg=xdulight}
\setbeamercolor{item}{fg=xdured}
\setbeamercolor{itemize item}{fg=xdured}
\setbeamercolor{itemize subitem}{fg=xdured2}
\setbeamercolor{enumerate item}{fg=white}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{itemize item}{\color{xdured}\small\textbullet}
\setbeamertemplate{itemize subitem}{\color{xdured2}\scriptsize$\blacktriangleright$}
\setbeamertemplate{enumerate item}{%
  \tikz[baseline=(n.base)]\node[
    fill=xdured,
    text=white,
    inner sep=1.5pt,
    minimum width=4mm,
    font=\bfseries\scriptsize
  ] (n) {\insertenumlabel};\,%
}

\setbeamertemplate{blocks}[rounded][shadow=false]
\setbeamerfont{block title}{series=\bfseries,size=\small}
\setbeamerfont{block body}{size=\small}
\setbeamertemplate{section in toc}{%
  \leavevmode
  \numbadge{\inserttocsectionnumber}\hspace{0.5em}\inserttocsection
}
\setbeamertemplate{subsection in toc}{}

\newcommand{\xduassetpath}{assets}
\newcommand{\xdusetassetpath}[1]{\renewcommand{\xduassetpath}{#1}}

\newcommand{\xduuniversitylogo}{\xduassetpath/xdulogo.pdf}
\newcommand{\xducoverbackground}{\xduassetpath/cover_bg.jpg}
\newcommand{\xducontentbackground}{\xduassetpath/content_bg.jpg}
\newcommand{\xdusectionbackground}{\xduassetpath/section_bg.jpg}
\newcommand{\xdumottoimage}{\xduassetpath/motto.png}

\newcommand{\advisor}[1]{\def\xduadvisor{#1}}
\newcommand{\xduadvisor}{待填写}

\newcommand{\xdusectionno}{00}
\newcommand{\xduformattedsection}{%
  \ifnum\value{section}<10 0\fi\thesection
}
\newlength{\xducardbodyheight}

\newcommand{\hl}[1]{\textcolor{xdured}{\textbf{#1}}}
\newcommand{\good}{\textcolor{xdured}{\ding{51}}}
\newcommand{\numbadge}[1]{%
  \tikz[baseline=(n.base)]\node[
    fill=xdured,
    text=white,
    inner xsep=3pt,
    inner ysep=1pt,
    font=\bfseries\footnotesize
  ] (n) {#1};%
}

\newcommand{\cardbox}[3]{%
  \setlength{\xducardbodyheight}{#1}%
  \addtolength{\xducardbodyheight}{-1.05cm}%
  \begin{minipage}[t][#1][t]{\linewidth}
    \begin{block}{#2}
      \begin{minipage}[t][\xducardbodyheight][c]{\linewidth}
        #3
      \end{minipage}
    \end{block}
  \end{minipage}%
}

\newcommand{\xduheader}{%
  \begin{tikzpicture}[remember picture,overlay]
    \node[anchor=north west,inner sep=0pt] at (current page.north west)
      {\includegraphics[width=\paperwidth,height=\paperheight]{\xducontentbackground}};
    \fill[xdured] (current page.north west) rectangle ([yshift=-0.18cm]current page.north east);
    \draw[xdured,line width=0.4pt] ([xshift=0.65cm,yshift=-1.20cm]current page.north west)
      -- ([xshift=-0.65cm,yshift=-1.20cm]current page.north east);
    \node[
      anchor=north west,
      xshift=0.65cm,
      yshift=-0.32cm,
      text=white,
      fill=xdured,
      inner xsep=5pt,
      inner ysep=2.5pt,
      font=\bfseries\footnotesize
    ] at (current page.north west) {\xdusectionno};
    \node[anchor=north east,xshift=-0.55cm,yshift=-0.34cm]
      at (current page.north east)
      {\includegraphics[height=0.66cm]{\xduuniversitylogo}};
  \end{tikzpicture}%
}

\setbeamertemplate{footline}{%
  \leavevmode%
  \hbox{%
    \begin{beamercolorbox}[wd=\paperwidth,ht=2.6ex,dp=1.4ex,rightskip=1.1cm,right]{}%
      \color{xdured}\bfseries\footnotesize \insertframenumber\,/\,\inserttotalframenumber
    \end{beamercolorbox}%
  }%
  \vspace{0.05cm}%
}

\setbeamertemplate{frametitle}{%
  \xduheader
  \vspace{0.05cm}
  \hspace{0.65cm}\begin{tikzpicture}[baseline]
    \node[anchor=base west,inner sep=0pt] (a) {\color{xdured}\rule[-0.05em]{2.4pt}{1.0em}};
    \node[anchor=base west,inner sep=0pt,xshift=6pt] at (a.base east)
      {\color{xdudark}\bfseries\large\insertframetitle};
  \end{tikzpicture}%
  \ifx\insertframesubtitle\@empty\else
    \\\hspace{0.95cm}\color{xdugray}\small\insertframesubtitle
  \fi
}

\makeatletter
\newcommand{\makexdutitle}{%
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture,overlay]
      \node[anchor=north west,inner sep=0pt] at (current page.north west)
        {\includegraphics[width=\paperwidth,height=\paperheight]{\xducoverbackground}};
      \node[anchor=north,yshift=-0.55cm]
        at (current page.north)
        {\includegraphics[height=0.42cm]{\xdumottoimage}};
      \node[anchor=north,yshift=-1.20cm]
        at (current page.north)
        {\includegraphics[height=1.10cm]{\xduuniversitylogo}};
      \node[anchor=center,text=xdured,font=\bfseries\fontsize{26}{32}\selectfont]
        at ([yshift=1.0cm]current page.center)
        {\parbox{14cm}{\centering \inserttitle}};
      \ifx\insertsubtitle\@empty\else
        \node[anchor=center,text=xdured,font=\bfseries\fontsize{13}{16}\selectfont]
          at ([yshift=-0.85cm]current page.center)
          {\insertsubtitle};
      \fi
      \node[anchor=north,yshift=-1.55cm,text=xdudark,font=\fontsize{11}{14}\selectfont]
        at (current page.center)
        {\renewcommand{\arraystretch}{1.30}\begin{tabular}{c@{\quad\quad}c@{\quad\quad}c}
          \color{xdured}\bfseries 汇报人 & \color{xdured}\bfseries 指导教师 & \color{xdured}\bfseries 单位 \\
          \insertauthor & \xduadvisor & \insertinstitute
        \end{tabular}};
      \node[anchor=center,yshift=-3.35cm,text=xdured,font=\bfseries\fontsize{11}{14}\selectfont]
        at (current page.center)
        {\insertdate};
    \end{tikzpicture}
  \end{frame}
}
\makeatother
\newcommand{\makexduoutline}{%
  \renewcommand{\xdusectionno}{00}
  \begin{frame}{目\quad 录}{CONTENTS}
    \vspace{0.25cm}
    \tableofcontents[
      sectionstyle=show/show,
      subsectionstyle=hide/hide/hide
    ]
  \end{frame}
}

\AtBeginSection[]
{
  \xdusectionpage{\xduformattedsection}{\insertsectionhead}
}

\newcommand{\xdusectionpage}[2]{%
  \renewcommand{\xdusectionno}{#1}
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture,overlay]
      \fill[white] (current page.north west) rectangle (current page.south east);
      \fill[xdured] (current page.north west) rectangle ([yshift=-0.30cm]current page.north east);
      \fill[xdured] ([xshift=0.55cm,yshift=-1.4cm]current page.north west)
        rectangle ([xshift=0.85cm,yshift=-1.7cm]current page.north west);
      \begin{scope}
        \clip ([xshift=0.60\paperwidth,yshift=-0.30cm]current page.north west)
          rectangle (current page.south east);
        \node[anchor=north east,inner sep=0pt]
          at ([yshift=-0.30cm]current page.north east)
          {\includegraphics[
            width=0.40\paperwidth,
            height=\dimexpr\paperheight-0.30cm\relax,
            keepaspectratio=false
          ]{\xdusectionbackground}};
      \end{scope}
      \fill[xdured]
        ([xshift=0.595\paperwidth,yshift=-0.30cm]current page.north west)
        -- ([xshift=0.635\paperwidth,yshift=-0.30cm]current page.north west)
        -- ([xshift=0.605\paperwidth]current page.south west)
        -- ([xshift=0.565\paperwidth]current page.south west) -- cycle;
      \fill[xdured!85]
        ([xshift=0.665\paperwidth,yshift=-0.30cm]current page.north west)
        -- ([xshift=0.695\paperwidth,yshift=-0.30cm]current page.north west)
        -- ([xshift=0.665\paperwidth]current page.south west)
        -- ([xshift=0.635\paperwidth]current page.south west) -- cycle;
      \node[anchor=west,xshift=1.2cm,text=xdured,font=\bfseries\fontsize{56}{56}\selectfont]
        at ([yshift=0.4cm]current page.west) {PART\,#1};
      \draw[xdured,line width=2pt]
        ([xshift=1.3cm,yshift=-1.0cm]current page.west)
        -- ([xshift=2.2cm,yshift=-1.0cm]current page.west);
      \node[anchor=west,xshift=1.2cm,text=xdured,font=\bfseries\fontsize{22}{26}\selectfont]
        at ([yshift=-1.75cm]current page.west) {#2};
      \node[anchor=west,xshift=1.2cm,text=xdugray,font=\fontsize{11}{14}\selectfont]
        at ([yshift=-2.45cm]current page.west) {XDU Beamer Presentation};
    \end{tikzpicture}
  \end{frame}
}

